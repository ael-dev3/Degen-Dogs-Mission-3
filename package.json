    "check:dashboard-ui": "python3 scripts/check_dashboard_ui.py",
    "validate:dashboard": "python3 scripts/validate_dashboard_consistency.py",
    "archive:mission2": "python3 scripts/archive_mission2_index.py",
    "archive:mission2:check": "python3 scripts/archive_mission2_index.py --check-config",
