{
  "name": "degen-dogs-mission-3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "data": "python3 scripts/build_dashboard.py",
    "archive:mission2": "python3 scripts/archive_mission2_index.py",
    "archive:mission2:check": "python3 scripts/archive_mission2_index.py --check-config",
    "archive:mission3:verify": "python3 scripts/archive_mission3_index.py --verify-only",
    "archive:mission3:index": "python3 scripts/archive_mission3_index.py --incremental --write-public",
    "archive:mission3:full": "python3 scripts/archive_mission3_index.py --full-refresh --write-public",
    "archive:mission3:health": "python3 scripts/check_mission3_archive.py",
    "refresh:archive": "bash scripts/refresh_archive_and_publish.sh",
    "refresh:publish": "bash scripts/refresh_and_publish.sh",
    "refresh:install": "bash scripts/install_hourly_refresh_launchd.sh",
    "dev": "vite --host 0.0.0.0 --base=/Degen-Dogs-Mission-3/",
    "build": "vite build --base=/Degen-Dogs-Mission-3/",
    "preview": "vite preview --host 0.0.0.0",
    "archive:mission1:discover": "python3 scripts/archive_mission1_discover.py",
    "archive:mission1:index": "python3 scripts/archive_mission1_index.py --incremental",
    "archive:mission1:full": "python3 scripts/archive_mission1_index.py --full-refresh",
    "archive:mission1:reconcile": "python3 scripts/archive_mission1_reconcile.py",
    "archive:mission1:check": "python3 scripts/archive_mission1_index.py --check-config"
  },
  "devDependencies": {
    "vite": "^8.0.13"
  }
}
