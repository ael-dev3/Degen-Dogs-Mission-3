# Optional but recommended Base RPC endpoint.
# Leave blank to use public defaults, subject to rate limits.
BASE_RPC_URL=

# Optional comma-separated fallback RPCs.
BASE_RPC_URLS=
BASE_LOG_RPC_URLS=

# Optional log fetch tuning.
BASE_FROM_BLOCK=40500000
BASE_LOG_CHUNK=5000
BASE_LOG_WORKERS=4
BASE_RPC_BATCH_LIMIT=10
DOG_METADATA_WORKERS=16
MISSION3_LOG_CACHE=1
MISSION3_LOG_CACHE_OVERLAP_BLOCKS=50
MISSION3_BALANCE_CACHE=1

# Optional identity and price context. Never commit real keys or secrets.
NEYNAR_API_KEY=
WOOF_USD_PRICE=
SUP_USD_PRICE=


# Optional archive/API keys for recovery work. Keep real values local only.
COINGECKO_API_KEY=
DUNE_API_KEY=

# Optional mission archive tuning.
MISSION2_LOG_CHUNK=5000
MISSION3_LOG_CHUNK=10000
MISSION3_LOG_WORKERS=4

# Optional precise onchain activity watcher.
# The hourly refresh remains the baseline; the watcher triggers extra refreshes only on real auction-house changes.
MISSION3_WATCHER_INTERVAL_SECONDS=60
MISSION3_WATCHER_COOLDOWN_SECONDS=180
MISSION3_WATCHER_BID_COOLDOWN_SECONDS=60
MISSION3_WATCHER_FORCE_REFRESH_AFTER_SECONDS=3600
MISSION3_WATCHER_LOOKBACK_BLOCKS=2000
MISSION3_WATCHER_SAFETY_OVERLAP_BLOCKS=50
MISSION3_WATCHER_LOG_CHUNK=2000
MISSION3_WATCHER_STATE_PATH=.local/mission3_onchain_tracker_state.json
MISSION3_WATCHER_LOCK_PATH=.local/mission3_onchain_tracker.lock
# Leave blank so launchd installs default to $DEGEN_DOGS_LOG_DIR/watch-onchain.log.
# Set only for explicit local-file overrides, or '-' for stdout-only dry runs.
MISSION3_WATCHER_LOG_PATH=
# Shared with scripts/refresh_and_publish.sh so hourly and event refreshes cannot overlap.
MISSION3_REFRESH_LOCK_PATH=~/Library/Caches/degen-dogs-mission3/refresh.lock
MISSION3_REFRESH_COMMAND="npm run data && npm run build"
MISSION3_WATCHER_AUTO_PUSH=0
# Defaults on only when MISSION3_WATCHER_AUTO_PUSH=1. Set explicitly for stricter local refreshes.
MISSION3_WATCHER_REQUIRE_CLEAN_TREE=0
MISSION3_WATCHER_REFRESH_TIMEOUT_SECONDS=1800
