# Optional but recommended Base RPC endpoint.
# Leave blank to use public defaults, subject to rate limits.
BASE_RPC_URL=

# Optional comma-separated fallback RPCs.
BASE_RPC_URLS=
BASE_LOG_RPC_URLS=

# Optional log fetch tuning.
BASE_FROM_BLOCK=40500000
BASE_LOG_CHUNK=5000
BASE_LOG_WORKERS=4
BASE_RPC_BATCH_LIMIT=10
DOG_METADATA_WORKERS=16

# Optional identity and price context. Never commit real keys or secrets.
NEYNAR_API_KEY=
WOOF_USD_PRICE=
SUP_USD_PRICE=

# Optional archive/API keys for recovery work. Keep real values local only.
COINGECKO_API_KEY=
DUNE_API_KEY=

# Optional mission archive tuning.
MISSION2_LOG_CHUNK=5000
MISSION3_LOG_CHUNK=10000
MISSION3_LOG_WORKERS=4

# Optional event-aware local runner watcher.
# The hourly refresh remains the baseline; the watcher triggers extra refreshes only on auction changes.
MISSION3_WATCHER_INTERVAL_SECONDS=300
MISSION3_WATCHER_COOLDOWN_SECONDS=300
MISSION3_WATCHER_FORCE_REFRESH_AFTER_SECONDS=0
MISSION3_WATCHER_LOG_WINDOW_BLOCKS=2000
MISSION3_WATCHER_LOG_CHUNK=2000
MISSION3_WATCHER_STATE_PATH=.local/mission3_watcher_state.json
MISSION3_WATCHER_LOCK_PATH=.local/mission3_watcher.lock
MISSION3_WATCHER_LOG_PATH=logs/watch-auction.log
MISSION3_REFRESH_COMMAND=npm run refresh:local
MISSION3_WATCHER_AUTO_PUSH=0
MISSION3_WATCHER_REQUIRE_CLEAN_TREE=1
MISSION3_WATCHER_REFRESH_TIMEOUT_SECONDS=1800
